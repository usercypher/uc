{
  "server": "0.0.0.0:8080",
  "document_root": "${ROOT}/web",
  "fcgi_enabled": true,
  "fcgi_network": "unix",
  "fcgi_address": "${ROOT}/var/run/php-cgi-${PORT}.sock",
  "fcgi_bin": "php-cgi -b ${ROOT}/var/run/php-cgi-${PORT}.sock -c ${ROOT}/php.ini",
  "fcgi_script": "${ROOT}/index.php",
  "fcgi_worker_count": 5,
  "fcgi_worker_concurrency": 1,
  "fcgi_env": {
    "PHP_FCGI_MAX_REQUESTS": "0"
  },
  "mime": {
    ".wasm": "application/wasm",
    ".webmanifest": "application/manifest+json",
    ".map": "application/json",
    ".md": "text/markdown; charset=utf-8",
    ".csv": "text/csv; charset=utf-8",
    ".txt": "text/plain; charset=utf-8",
    ".xml": "application/xml",
    ".yaml": "application/yaml",
    ".yml": "application/yaml",
    ".svg": "image/svg+xml",
    ".ico": "image/x-icon",
    ".woff": "font/woff",
    ".woff2": "font/woff2",
    ".otf": "font/otf",
    ".ttf": "font/ttf"
  },
  "read_header_timeout": 5,
  "read_timeout": 30,
  "write_timeout": 30,
  "idle_timeout": 60,
  "max_header_bytes": 1048576,
  "max_body_bytes": 16777216,
  "encoding": 9,
  "encoding_dir": "${ROOT}/var/lib/encoding/",
  "encoding_interval": 3600,
  "encoding_retention": 86400,
  "encoding_min_bytes": 256,
  "encoding_max_bytes": 134217728,
  "encoding_mime": [
    "text/plain",
    "text/html",
    "text/css",
    "text/javascript",
    "text/markdown",
    "application/javascript",
    "application/json",
    "application/xml",
    "application/yaml",
    "application/wasm",
    "application/manifest+json",
    "image/svg+xml",
    "font/woff",
    "font/woff2"
  ],
  "rules": [
    {
      "X-Uc-Web-Match-Any": "/uc-fcgi.json",
      "X-Uc-Web-Redirect": "${REQ_PATH} ${REQ_DIR} ${REQ_BASENAME} ${REQ_NAME} ${REQ_EXT}"
    },
    {
      "X-Uc-Web-Match-Any": "^/",
      "X-Content-Type-Options": "nosniff",
      "Referrer-Policy": "strict-origin-when-cross-origin",
      "Permissions-Policy": "geolocation=(), microphone=(), camera=()",
      "Cross-Origin-Opener-Policy": "same-origin",
      "Cross-Origin-Resource-Policy": "same-origin"
    },
    {
      "X-Uc-Web-Match-Any": "^/asset/",
      "X-Uc-Web-Encoding": "gzip",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    {
      "X-Uc-Web-Match-Any": "$.html, $.json, $.txt, $.xml",
      "X-Uc-Web-Encoding": "gzip",
      "Cache-Control": "no-cache"
    },
    {
      "X-Uc-Web-Match-Any": "$.css, $.js, $.svg",
      "X-Uc-Web-Encoding": "gzip",
      "Cache-Control": "public, max-age=31536000, immutable"
    },
    {
      "X-Uc-Web-Match-Any": "/favicon.ico",
      "Cache-Control": "public, max-age=604800"
    },
    {
      "X-Uc-Web-Match-Any": "/robots.txt",
      "Cache-Control": "public, max-age=86400"
    }
  ]
}