CREATE TABLE player (
    id TEXT PRIMARY KEY,
    x REAL NOT NULL DEFAULT 50.0,
    y REAL NOT NULL DEFAULT 50.0,
    color TEXT NOT NULL,
    lives INTEGER NOT NULL DEFAULT 3,
    bullets TEXT NOT NULL DEFAULT '[]',
    dir_x INTEGER NOT NULL DEFAULT 0,
    dir_y INTEGER NOT NULL DEFAULT 1,
    keys_state TEXT NOT NULL DEFAULT '{"up":false,"down":false,"left":false,"right":false}',
    last_fire INTEGER NOT NULL
);

CREATE TABLE tick (
    id INTEGER PRIMARY KEY CHECK (id = 1) DEFAULT 1,
    last_tick_time REAL NOT NULL DEFAULT 0.0
);

INSERT OR IGNORE INTO tick (id, last_tick_time) VALUES (1, 0.0);